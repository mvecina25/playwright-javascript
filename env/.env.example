# ==============================================================================
# ENVIRONMENT CONFIGURATION: SYSTEM UNDER TEST (SUT)
# ==============================================================================

# WHY: We target the publicly hosted ParaBank instance by default. 
# This ensures the suite is "CI-Ready" and can be executed from any runner 
# without requiring a local infrastructure setup.
APP_BASE_URL=https://parabank.parasoft.com

# WHY: Switch to the Dockerized instance for high-speed, isolated local 
# development. Use this to bypass external network latency or when testing 
# destructive data scenarios (like database resets) that aren't possible 
# on the shared public instance.
# APP_BASE_URL=http://localhost:3000